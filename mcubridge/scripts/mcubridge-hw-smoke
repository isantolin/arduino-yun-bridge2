#!/usr/bin/env python3
"""Run a basic McuBridge hardware smoke test locally on the device.

[SIL-2] Improved robustness using Python 'sh' library and structured validation.
"""

from __future__ import annotations

import json
import os
import sys
import time
from pathlib import Path
from typing import Any

try:
    import sh
except ImportError:
    print("[mcubridge-hw-smoke] ERROR: 'sh' library is required. Install 'python3-sh'.", file=sys.stderr)
    sys.exit(1)

STATUS_FILE = Path("/tmp/mcubridge_status.json")

def uci_get(key: str, default: str = "") -> str:
    try:
        return str(sh.uci("-q", "get", f"mcubridge.general.{key}")).strip()
    except sh.ErrorReturnCode:
        return default

def main() -> None:
    # 1. Dependency Check
    for cmd in ["mosquitto_pub", "mosquitto_sub"]:
        if not sh.which(cmd):
            print(f"[mcubridge-hw-smoke] ERROR: {cmd} is required. Install 'mosquitto-client'.", file=sys.stderr)
            sys.exit(1)

    # 2. Configuration Load
    serial_secret = uci_get("serial_shared_secret")
    if not serial_secret or serial_secret == "changeme123":
        print("[mcubridge-hw-smoke] ERROR: Serial secret missing or insecure.", file=sys.stderr)
        sys.exit(1)

    host = uci_get("mqtt_host", "127.0.0.1")
    port = uci_get("mqtt_port", "8883")
    topic_prefix = uci_get("mqtt_topic", "br")
    tls_enabled = uci_get("mqtt_tls", "1") == "1"
    user = uci_get("mqtt_user")
    pw = uci_get("mqtt_pass")
    cafile = uci_get("mqtt_cafile")
    insecure = uci_get("mqtt_tls_insecure", "0") == "1"

    # 3. Environment Check
    init_script = Path("/etc/init.d/mcubridge")
    if init_script.exists():
        try:
            sh.Command(str(init_script))("status")
        except sh.ErrorReturnCode:
            print("[mcubridge-hw-smoke] ERROR: McuBridge service is not running.", file=sys.stderr)
            sys.exit(1)

    if not STATUS_FILE.exists() or STATUS_FILE.stat().st_size == 0:
        print(f"[mcubridge-hw-smoke] ERROR: Status file {STATUS_FILE} missing or empty.", file=sys.stderr)
        sys.exit(1)

    # 4. Prepare Mosquitto Arguments
    common_args: list[str] = ["-h", host, "-p", port]
    if user: common_args.extend(["-u", user])
    if pw: common_args.extend(["-P", pw])

    if tls_enabled:
        if cafile and Path(cafile).exists():
            common_args.extend(["--cafile", cafile])
        elif Path("/etc/ssl/certs/ca-certificates.crt").exists():
            common_args.extend(["--cafile", "/etc/ssl/certs/ca-certificates.crt"])
        if insecure:
            common_args.append("--insecure")

    # 5. Run Smoke Test (Round Trip)
    print(f"[mcubridge-hw-smoke] Checking MQTT round trip via {host}:{port}...", file=sys.stderr)
    
    status_topic = f"{topic_prefix}/system/status"
    request_topic = f"{topic_prefix}/system/status/request"
    
    try:
        # Start subscriber in background
        sub_proc = sh.mosquitto_sub(
            *common_args, 
            "-t", status_topic, 
            "-C", "1", 
            "-W", "7", 
            _bg=True
        )
        
        time.sleep(1) # Wait for sub to establish
        
        # Publish request
        sh.mosquitto_pub(
            *common_args,
            "-t", request_topic,
            "-m", '{"request":"ping"}'
        )
        
        # Wait for sub result
        output = sub_proc.wait()
        print("[mcubridge-hw-smoke] Received response:")
        print(output.stdout.decode())
        print("[mcubridge-hw-smoke] Smoke test completed successfully.", file=sys.stderr)

    except sh.TimeoutException:
        print("[mcubridge-hw-smoke] ERROR: Did not receive response from daemon (Timeout).", file=sys.stderr)
        sys.exit(1)
    except sh.ErrorReturnCode as e:
        print(f"[mcubridge-hw-smoke] ERROR: MQTT tool failed: {e.stderr.decode()}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"[mcubridge-hw-smoke] FATAL ERROR: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()

{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.pytestPath": "${workspaceFolder}/.venv/bin/pytest",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "."
  ],
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/mcubridge-library-arduino/src/**",
    "${workspaceFolder}/mcubridge-library-arduino/tests/**",
    "${workspaceFolder}/tools/arduino_stub/include/**",
    "${workspaceFolder}/.tmp_tests/arduino_libs/Embedded_Template_Library/include/**",
    "${workspaceFolder}/.tmp_tests/arduino_libs/Embedded_Template_Library/arduino/**",
    "${workspaceFolder}/.tmp_tests/arduino_libs/wolfSSL/**",
    "${workspaceFolder}/.tmp_tests/arduino_libs/PacketSerial/src/**",
    "~/Arduino/libraries/**"
  ],
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "makefile.configureOnOpen": false,
  "makefile.configureAfterCommand": false,
  "makefile.loggingLevel": "Normal",
  "makefile.dryrunSwitches": [],
  "python.analysis.autoImportCompletions": true,
  "flake8.interpreter": [
    "${workspaceFolder}/.venv/bin/python"
  ],
  "flake8.path": [
    "${workspaceFolder}/.venv/bin/flake8"
  ],
  "python.analysis.languageServerMode": "full",
  "markdown.validate.enabled": true
}

{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${default}",
                "${workspaceFolder}/mcubridge-library-arduino/src/**",
                "${workspaceFolder}/tools/arduino_stub/include",
                "${workspaceFolder}/.dummy_libs/Embedded_Template_Library",
                "${workspaceFolder}/.dummy_libs/Embedded_Template_Library/include",
                "${workspaceFolder}/.dummy_libs/Embedded_Template_Library/arduino",
                "${workspaceFolder}/.dummy_libs/wolfssl",
                "${workspaceFolder}/.dummy_libs/PacketSerial/src"
            ],
            "defines": [
                "BRIDGE_HOST_TEST=1",
                "BRIDGE_TEST_NO_GLOBALS=1",
                "WOLFSSL_USER_SETTINGS",
                "ETL_NO_STL",
                "BRIDGE_ENABLE_CONSOLE=1",
                "BRIDGE_ENABLE_DATASTORE=1",
                "BRIDGE_ENABLE_MAILBOX=1",
                "BRIDGE_ENABLE_FILESYSTEM=1",
                "BRIDGE_ENABLE_PROCESS=1",
                "BRIDGE_ENABLE_SPI=1"
            ],
            "compilerPath": "/usr/bin/g++",
            "intelliSenseMode": "linux-gcc-x64",
            "cppStandard": "c++17",
            "cStandard": "c17"
        }
    ],
    "version": 4
}
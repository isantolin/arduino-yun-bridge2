{
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "mcubridge/tests",
    "mcubridge-client-examples/client_tests"
  ],
  "python.analysis.extraPaths": [
    "mcubridge",
    "stubs",
    "mcubridge-client-examples"
  ],
  "python.envFile": "${workspaceFolder}/.env",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/mcubridge-library-arduino/src/**",
    "${workspaceFolder}/mcubridge-library-arduino/tests/**",
    "${workspaceFolder}/tools/arduino_stub/include/**"
  ],
  "C_Cpp.default.cppStandard": "c++14",
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "makefile.makefilePath": "mcubridge/Makefile",
  "makefile.configurations": [
    {
      "name": "mcubridge-daemon",
      "makefilePath": "mcubridge/Makefile"
    },
    {
      "name": "luci-app",
      "makefilePath": "luci-app-mcubridge/Makefile"
    }
  ]
}
#!/usr/bin/env python3
"""Simple script to control MCU pins (like LED 13) from OpenWrt via MQTT.

Usage: mcubridge-led-control on|off [pin]
"""

from __future__ import annotations

import sh
import uci
import sys
import tenacity
import typer
from pathlib import Path
from typing import Annotated

app = typer.Typer(add_completion=False)

def uci_get(key: str, default: str = "") -> str:
    try:
        u = uci.Uci()
        return u.get("mcubridge", "general", key)
    except (uci.UciException, RuntimeError):
        return default

@app.command()
def main(
    state_arg: Annotated[str, typer.Argument(help="State to set the LED to (on/off)")],
    pin: Annotated[int, typer.Argument(help="Pin number to control")] = 13
) -> None:
    state_arg = state_arg.lower()
    if state_arg not in ("on", "off"):
        sys.stderr.write(f"Error: invalid state '{state_arg}'. Use on|off.\n")
        raise typer.Exit(code=2)

    payload = "1" if state_arg == "on" else "0"
    
    topic_prefix = uci_get("mqtt_topic", "br")
    mqtt_topic = f"{topic_prefix}/d/{pin}"
    
    # MQTT Config
    common_args = [
        "-h", uci_get("mqtt_host", "127.0.0.1"),
        "-p", uci_get("mqtt_port", "8883"),
        "-t", mqtt_topic,
        "-m", payload,
    ]
    
    user = uci_get("mqtt_user")
    if user: common_args.extend(["-u", user])
    
    pw = uci_get("mqtt_pass")
    if pw: common_args.extend(["-P", pw])

    if uci_get("mqtt_tls", "1") == "1":
        cafile = uci_get("mqtt_cafile")
        if cafile and Path(cafile).exists():
            common_args.extend(["--cafile", cafile])
        elif Path("/etc/ssl/certs/ca-certificates.crt").exists():
            common_args.extend(["--cafile", "/etc/ssl/certs/ca-certificates.crt"])
        
        if uci_get("mqtt_tls_insecure", "0") == "1":
            common_args.append("--insecure")
        
        common_args.extend(["--tls-version", "tlsv1.2"])

    @tenacity.retry(
        stop=tenacity.stop_after_attempt(3),
        wait=tenacity.wait_fixed(0.5),
        retry=tenacity.retry_if_exception_type(sh.ErrorReturnCode),
        reraise=True
    )
    def do_publish():
        sh.mosquitto_pub(*common_args)
        sh.logger("-t", "mcubridge-led", f"Published LED{pin}={payload} to {mqtt_topic}")

    try:
        do_publish()
    except sh.ErrorReturnCode as e:
        sh.logger("-t", "mcubridge-led", "-p", "daemon.err", f"Failed to publish after retries: {e.stderr.decode()}")
        sys.stderr.write(f"Error: failed to publish MQTT message: {e}\n")
        raise typer.Exit(code=4)

if __name__ == "__main__":
    app()

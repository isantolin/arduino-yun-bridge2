{
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "mcubridge/tests",
    "mcubridge-client-examples/client_tests"
  ],
  "python.envFile": "${workspaceFolder}/.env",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/mcubridge-library-arduino/src/**",
    "${workspaceFolder}/.dummy_libs/Embedded_Template_Library/include/**",
    "${workspaceFolder}/mcubridge-library-arduino/tests/**",
    "${workspaceFolder}/tools/arduino_stub/include/**"
  ],
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "makefile.configureOnOpen": false,
  "makefile.configureAfterCommand": false,
  "makefile.loggingLevel": "Normal",
  "makefile.dryrunSwitches": [],
  "python.analysis.autoImportCompletions": true,
  "flake8.interpreter": [
    "${workspaceFolder}/.tox/py313/bin/python"
  ],
  "flake8.path": [
    "${workspaceFolder}/.tox/py313/bin/flake8"
  ]
}
#!/usr/bin/env python3
"""Run a basic McuBridge hardware smoke test locally on the device.

[SIL-2] Improved robustness using Python 'sh' library and structured validation.
"""

from __future__ import annotations

import sh
import os
import sys
import typer
from pathlib import Path
from typing import Any, Annotated
import msgspec
import tenacity

app = typer.Typer(add_completion=False)
STATUS_FILE = Path("/tmp/mcubridge_status.json")

def uci_get(key: str, default: str = "") -> str:
    try:
        return str(sh.uci("-q", "get", f"mcubridge.general.{key}")).strip()
    except sh.ErrorReturnCode:
        return default

@app.command()
def main() -> None:
    # 1. Dependency Check
    for cmd in ["mosquitto_pub", "mosquitto_sub"]:
        if not sh.which(cmd):
            sys.stderr.write(f"[mcubridge-hw-smoke] ERROR: {cmd} is required. Install 'mosquitto-client'.\n")
            raise typer.Exit(code=1)

    # 2. Configuration Load
    serial_secret = uci_get("serial_shared_secret")
    if not serial_secret or serial_secret == "changeme123":
        sys.stderr.write("[mcubridge-hw-smoke] ERROR: Serial secret missing or insecure.\n")
        raise typer.Exit(code=1)

    host = uci_get("mqtt_host", "127.0.0.1")
    port = uci_get("mqtt_port", "8883")
    topic_prefix = uci_get("mqtt_topic", "br")
    tls_enabled = uci_get("mqtt_tls", "1") == "1"
    user = uci_get("mqtt_user")
    pw = uci_get("mqtt_pass")
    cafile = uci_get("mqtt_cafile")
    insecure = uci_get("mqtt_tls_insecure", "0") == "1"

    # 3. Environment Check
    init_script = Path("/etc/init.d/mcubridge")
    if init_script.exists():
        try:
            sh.Command(str(init_script))("status")
        except sh.ErrorReturnCode:
            sys.stderr.write("[mcubridge-hw-smoke] ERROR: McuBridge service is not running.\n")
            raise typer.Exit(code=1)

    if not STATUS_FILE.exists() or STATUS_FILE.stat().st_size == 0:
        sys.stderr.write(f"[mcubridge-hw-smoke] ERROR: Status file {STATUS_FILE} missing or empty.\n")
        raise typer.Exit(code=1)

    # 4. Prepare Mosquitto Arguments
    common_args: list[str] = ["-h", host, "-p", port]
    if user: common_args.extend(["-u", user])
    if pw: common_args.extend(["-P", pw])

    if tls_enabled:
        if cafile and Path(cafile).exists():
            common_args.extend(["--cafile", cafile])
        elif Path("/etc/ssl/certs/ca-certificates.crt").exists():
            common_args.extend(["--cafile", "/etc/ssl/certs/ca-certificates.crt"])
        if insecure:
            common_args.append("--insecure")

    # 5. Run Smoke Test (Round Trip)
    sys.stderr.write(f"[mcubridge-hw-smoke] Checking MQTT round trip via {host}:{port}...\n")
    
    status_topic = f"{topic_prefix}/system/status"
    request_topic = f"{topic_prefix}/system/status/request"
    
    @tenacity.retry(
        stop=tenacity.stop_after_delay(15),
        wait=tenacity.wait_fixed(1.0),
        retry=tenacity.retry_if_exception_type((sh.TimeoutException, TimeoutError, sh.ErrorReturnCode)),
        reraise=True
    )
    def perform_round_trip() -> str:
        # Declarative background subscriber
        # (W=2 means wait max 2 seconds for a message)
        with sh.mosquitto_sub(*common_args, t=status_topic, C=1, W=2, _bg=True) as sub:
            # Publish request
            sh.mosquitto_pub(*common_args, t=request_topic, m='{"request":"ping"}')
            # The context manager ensures cleanup, we just wait for the output
            return str(sub.wait())

    try:
        response = perform_round_trip()
        sys.stdout.write("[mcubridge-hw-smoke] Received response:\n")
        sys.stdout.write(response + "\n")
        sys.stderr.write("[mcubridge-hw-smoke] Smoke test completed successfully.\n")

    except (sh.TimeoutException, TimeoutError):
        sys.stderr.write("[mcubridge-hw-smoke] ERROR: Did not receive response from daemon (Timeout).\n")
        raise typer.Exit(code=1)
    except (sh.ErrorReturnCode, OSError, ValueError) as e:
        sys.stderr.write(f"[mcubridge-hw-smoke] ERROR: System or tool failed: {e}\n")
        raise typer.Exit(code=1)

if __name__ == "__main__":
    app()
